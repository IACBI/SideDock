<Window x:Class="SideDock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SideDock"
        Width="64"
        Height="600"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        AllowsTransparency="True"
        Background="Transparent"
        Left="0" Top="0">
    <!--
        Width="64"            : the dock's thickness (changed/styled later).
        Height="600"          : a placeholder; the AppBar code resizes us to the
                                full screen height at runtime.
        WindowStyle="None"    : no title bar / borderless.
        ResizeMode="NoResize" : user can't drag-resize it.
        Topmost="True"        : always on top.
        ShowInTaskbar="False" : the dock shouldn't appear as a taskbar button.
        Left/Top + Manual     : we position it ourselves via the AppBar API.
    -->

    <!-- Dark vertical bar; app buttons are added to AppList at runtime.
         RootBar's Background and the text/divider colors are set from config. -->
    <Border x:Name="RootBar">
        <!-- Right-clicking anywhere on the bar opens this menu. It's the always
             -visible alternative to the system-tray icon (which Windows 11 may
             hide in the overflow flyout). -->
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Hide dock" Click="OnMenuHide"/>
                <MenuItem Header="Open config file" Click="OnMenuOpenConfig"/>
                <Separator/>
                <MenuItem Header="Exit SideDock" Click="OnMenuExit"/>
            </ContextMenu>
        </Border.ContextMenu>

        <!-- Background is set from config in ApplyConfig(); the Transparent
             placeholder keeps the bar hit-testable until that runs. -->
        <Border.Background>Transparent</Border.Background>

        <!-- DockPanel: clock pinned to the bottom, app list fills the rest. -->
        <DockPanel>
            <!-- Clock at the bottom of the bar, updated by a timer. -->
            <StackPanel x:Name="ClockPanel"
                        DockPanel.Dock="Bottom"
                        Margin="0,8,0,12"
                        HorizontalAlignment="Center">
                <TextBlock x:Name="TimeText"
                           Foreground="#FFE6E6F0"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Text="--:--"/>
                <TextBlock x:Name="DateText"
                           Foreground="#FF9A9AB0"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           Text="---"/>
            </StackPanel>

            <!-- ScrollViewer so long lists can still scroll on short screens. -->
            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Vertical" Margin="0,10">
                    <!-- Pinned app launchers (Phase 2). -->
                    <StackPanel x:Name="AppList" Orientation="Vertical"/>

                    <!-- Divider, shown only when there are open windows below. -->
                    <Separator x:Name="WindowSeparator"
                               Margin="12,8"
                               Background="#33FFFFFF"
                               Visibility="Collapsed"/>

                    <!-- Currently open windows (Phase 4), refreshed by a timer. -->
                    <StackPanel x:Name="WindowList" Orientation="Vertical"/>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
