<Application x:Class="SideDock.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Defaults overridden by MainWindow at runtime from the config theme,
             so hover/press colors and corner roundness are customizable. -->
        <SolidColorBrush x:Key="DockHoverBrush" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="DockPressedBrush" Color="#55FFFFFF"/>
        <CornerRadius x:Key="DockButtonCornerRadius" TopLeft="8" TopRight="8"
                      BottomRight="8" BottomLeft="8"/>

        <!--
            Style for the dock's app buttons: borderless, transparent, with a
            rounded highlight on hover/press. Applied by key in MainWindow.
        -->
        <Style x:Key="DockButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="8,6"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{DynamicResource DockButtonCornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background"
                                        Value="{DynamicResource DockHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background"
                                        Value="{DynamicResource DockPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
